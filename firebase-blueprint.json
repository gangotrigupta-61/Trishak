{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["guest", "receptionist", "staff", "security", "admin", "responder"] },
        "organizationId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "guestTokenId": { "type": "string" },
        "verifiedBy": { "type": "string" },
        "lastLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Guest": {
      "title": "Guest",
      "description": "Guest record for verification",
      "type": "object",
      "properties": {
        "guestId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "organizationId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "used", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["guestId", "name", "phone", "organizationId", "status"]
    },
    "GuestToken": {
      "title": "GuestToken",
      "description": "Unique ID generated by receptionist for guest verification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "receptionistId": { "type": "string" },
        "organizationId": { "type": "string" },
        "guestId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "used", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "receptionistId", "status", "createdAt", "organizationId"]
    },
    "Incident": {
      "title": "Incident",
      "description": "An emergency event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["fire", "medical", "theft", "other"] },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "status": { "type": "string", "enum": ["reported", "acknowledged", "responding", "resolved", "closed"] },
        "organizationId": { "type": "string" },
        "reporterId": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" },
            "floor": { "type": "string" },
            "zone": { "type": "string" }
          }
        },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "responders": { "type": "array", "items": { "type": "string" } },
        "aiSummary": { "type": "string" },
        "aiResponsePlan": { "type": "string" }
      },
      "required": ["type", "severity", "status", "reporterId", "location", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Real-time chat message in an incident room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "incidentId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "system", "image", "voice"] },
        "mediaUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["incidentId", "senderId", "text", "timestamp"]
    },
    "RoleCode": {
      "title": "RoleCode",
      "description": "Unique code for staff registration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "role": { "type": "string", "enum": ["receptionist", "staff", "security", "admin", "responder"] },
        "organizationId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "role", "organizationId", "status", "createdAt"]
    },
    "Organization": {
      "title": "Organization",
      "description": "A parent organization record",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["hospital", "hotel", "restaurant"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "adminId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "name", "type", "adminId"]
    }
  },
  "firestore": {
    "/organizations/{orgId}": {
      "schema": "Organization",
      "description": "Organization records"
    },
    "/roleCodes/{codeId}": {
      "schema": "RoleCode",
      "description": "Role codes for staff registration"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/incidents/{incidentId}": {
      "schema": "Incident",
      "description": "Emergency incidents"
    },
    "/incidents/{incidentId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Incident chat messages"
    },
    "/guestTokens/{tokenId}": {
      "schema": "GuestToken",
      "description": "Tokens for guest verification"
    },
    "/guests/{guestId}": {
      "schema": "Guest",
      "description": "Guest records for verification"
    }
  }
}
